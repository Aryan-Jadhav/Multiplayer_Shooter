# This .gitignore file should be placed at the root of your Unity project

############################
# Unity Generated Folders
############################
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
UserSettings/
MemoryCaptures/

############################
# Visual Studio / Rider
############################
.vs/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

############################
# JetBrains Rider
############################
.idea/
*.sln.iml

############################
# OS Generated Files
############################
.DS_Store
Thumbs.db
Desktop.ini

############################
# Unity Cloud Build
############################
sysinfo.txt

############################
# Crash Reports
############################
sysinfo.txt

############################
# Addressables
############################
/Assets/AddressableAssetsData/*/*.bin*

############################
# Build artifacts
############################
*.apk
*.aab
*.unitypackage
*.app
*.exe

############################
# Generated files
############################
*.pidb.meta
*.pdb.meta
*.mdb.meta

############################
# Auto Generated Lighting
############################
Assets/LightingData.asset
Assets/LightingData.asset.meta